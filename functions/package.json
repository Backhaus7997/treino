{
  "name": "treino-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for TREINO",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "test": "jest --forceExit",
    "test:rules": "jest --forceExit \"(user-public-profiles-rules|trainer-links-paywall-rules|users-subscription-rules|users-role-create-rules|trainer-links-forge-rules|chat-relationship-rules)\"",
    "test:rules:emulator": "firebase emulators:exec --only firestore,auth --project treino-rules-test \"npm run test:rules\"",
    "lint": "eslint --ext .ts src/",
    "lint:fix": "eslint --ext .ts src/ --fix"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-google": "^0.14.0",
    "firebase-functions-test": "^3.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.0"
  },
  "private": true
}
