{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "treino-dev",
          "appId": "1:1079774251763:android:6810a95a4b3dce9b3f8586",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "treino-dev",
          "appId": "1:1079774251763:ios:c292394709b082553f8586",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "treino-dev",
          "configurations": {
            "android": "1:1079774251763:android:6810a95a4b3dce9b3f8586",
            "ios": "1:1079774251763:ios:006f7766b93ce5dc3f8586",
            "web": "1:1079774251763:web:e78f5ea99effb1593f8586"
          }
        }
      }
    }
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": [
    {
      "target": "coach-hub-dev",
      "public": "build/web",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ],
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20",
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
    }
  ],
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "functions": { "port": 5001 },
    "storage": { "port": 9199 },
    "hosting": { "port": 5000 },
    "ui": { "enabled": true, "port": 4444 },
    "singleProjectMode": true
  }
}
