rules_version = '2';

// Firebase Storage security rules for TREINO.
// Admin SDK in Cloud Functions bypasses these entirely (ADR-ACCDEL-013).
service firebase.storage {
  match /b/{bucket}/o {
    // Avatars: any image extension owned by the authenticated user.
    // Path pattern: /avatars/{uid}.{ext}  e.g. avatars/abc123.jpg, avatars/abc123.heic
    match /avatars/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                  && fileName.matches(request.auth.uid + '\\..+')
                  && request.resource.size < 5 * 1024 * 1024
                  && request.resource.contentType.matches('image/.*');
    }

    // Excel imports: trainers upload Excel plan files under /temp/uploads/{uid}/...
    // Authenticated users can write to their own folder; reads denied (server-only).
    match /temp/uploads/{userId}/{file=**} {
      allow read: if false;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Custom exercise tutorial videos: a trainer uploads short clips
    // (MP4 / MOV / M4V, max 100 MB) under /customExerciseVideos/{uid}/...
    // Anyone authenticated can read so the trainer's athletes can play
    // them inline; only the owner can write or delete.
    match /customExerciseVideos/{userId}/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                  && request.auth.uid == userId
                  && request.resource.size < 100 * 1024 * 1024
                  && request.resource.contentType.matches('video/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Chat media — photos and videos sent inside 1-1 chats (REQ-CHATMEDIA-007).
    //
    // Path: /chatMedia/{chatId}/{userId}/{file}
    //
    // Membership gate (rules-hardening Slice A / AD-2): chatId is
    // deterministic (ChatRepository.chatIdFor = sorted([a,b]).join('_')) and
    // uids are enumerable (userPublicProfiles is world-readable), so a plain
    // `request.auth != null` read let any authenticated account reconstruct
    // and download/list another pair's private media. Storage rules CAN call
    // firestore.get() cross-service (the old in-file comment claiming
    // otherwise was outdated) — `get` is now gated by `chats/{chatId}.members`
    // membership, and `list` is closed unconditionally (Storage `list` cannot
    // be scoped per-object, so per-uid folder enumeration would still leak
    // other users' media paths even with the `get` gate in place).
    //
    // NOTE: the literal `(default)` database name is required here — Storage
    // rules have no `$(database)` wildcard (that binds from the Firestore
    // `match /databases/{database}/documents` header, which does not exist
    // in this rules file).
    //
    // Size limits: images < 15 MB, videos < 100 MB (server-side guard mirrors
    // the client-side guard in ChatMediaUploadService).
    match /chatMedia/{chatId}/{userId}/{file=**} {
      // Only members of this chat can download individual media objects.
      allow get: if request.auth != null
                 && request.auth.uid in
                    firestore.get(/databases/(default)/documents/chats/$(chatId)).data.members;

      // list is unconditionally closed — never expose the folder listing,
      // not even to members.
      allow list: if false;

      // Only the owner can upload; content type and size are allowlisted.
      allow write: if request.auth != null
                  && request.auth.uid == userId
                  && (
                       (request.resource.contentType.matches('image/.*')
                        && request.resource.size < 15 * 1024 * 1024)
                       ||
                       (request.resource.contentType.matches('video/.*')
                        && request.resource.size < 100 * 1024 * 1024)
                     );

      // Only the owner can delete (cleanup on send failure or exercise removal).
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Coach Hub — archivos privados que el PF sube sobre un alumno.
    //
    // Path: /athleteFiles/{trainerId}_{athleteId}/{file}
    //
    // Trainer-only. El alumno NUNCA lee estos archivos. Nadie más los ve.
    // Enforce del par en el prefijo del path (`trainerId_athleteId`) para
    // que un attacker no pueda listar archivos de otro PF.
    //
    // Content types permitidos: PDF + imágenes. Videos y otros formatos
    // se rechazan explícitamente para MVP.
    //
    // Size limit: 10 MB, mirror del cap en el repository y en la Firestore
    // rule sobre athlete_files.
    match /athleteFiles/{pairId}/{file=**} {
      // Solo el trainer del par lee/escribe. Verificamos que `pairId`
      // arranque con el uid del caller — si arranca con otro uid, es un
      // fishing attempt y lo bloqueamos.
      allow read: if request.auth != null
                  && pairId.split('_')[0] == request.auth.uid;

      allow write: if request.auth != null
                   && pairId.split('_')[0] == request.auth.uid
                   && (
                        (request.resource.contentType == 'application/pdf'
                         && request.resource.size < 10 * 1024 * 1024)
                        ||
                        (request.resource.contentType.matches('image/.*')
                         && request.resource.size < 10 * 1024 * 1024)
                      );

      allow delete: if request.auth != null
                    && pairId.split('_')[0] == request.auth.uid;
    }

    // Default: deny all other access.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
