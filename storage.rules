rules_version = '2';

// Firebase Storage security rules for TREINO.
// Client access rules — Admin SDK in Cloud Functions bypasses these entirely (ADR-ACCDEL-013).
service firebase.storage {
  match /b/{bucket}/o {
    // Avatars: authenticated users can read/write their own avatar
    match /avatars/{userId}.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
