rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      // Owner-only read.
      allow read: if request.auth != null
                  && request.auth.uid == uid;

      // Create: only the authenticated user can create their own doc,
      // role MUST be one of the two valid values, and uid MUST match doc id.
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.role in ['athlete', 'trainer'];

      // Update: only the owner can update, and the four immutable fields
      // MUST equal their previous values. Trainers via Admin SDK only;
      // email changes via FirebaseAuth re-verification flow.
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    // uid: identity — must equal doc id forever.
                    && request.resource.data.uid == resource.data.uid
                    // role: AGENTS.md rule 3 — intrinsic, never client-mutable.
                    && request.resource.data.role == resource.data.role
                    // email: must use FirebaseAuth.updateEmail re-verification.
                    && request.resource.data.email == resource.data.email
                    // createdAt: audit field — preserves analytics integrity.
                    && request.resource.data.createdAt == resource.data.createdAt;

      // Delete denied — account deletion goes through privileged Cloud Function.
      allow delete: if false;
    }

    match /exercises/{exerciseId} {
      // Catálogo público para usuarios autenticados.
      allow read: if request.auth != null;
      // Catálogo writeable solo via Admin SDK (seed script).
      allow write: if false;
    }

    match /routines/{routineId} {
      // Catálogo público para usuarios autenticados.
      allow read: if request.auth != null;
      // Rutinas writeables solo via Admin SDK (seed script).
      allow write: if false;
    }

    match /posts/{postId} {
      // Any authenticated user can read posts (friends-privacy is soft / client-side).
      // REQ-PFM-009
      allow read: if request.auth != null;

      // Create: only the owner of the post — authorUid must equal caller uid.
      // SCENARIO-130: non-owner create is blocked.
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.authorUid;

      // Update and delete: only the original author.
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.authorUid;
    }

    match /friendships/{friendshipId} {
      // Read: only members of the friendship. SCENARIO-131: non-member blocked.
      // REQ-PFM-010
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.members;

      // Create: only by the requester, with status='pending', requester in members.
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.requesterId
                    && request.resource.data.status == 'pending'
                    && request.auth.uid in request.resource.data.members;

      // Update: only the non-requester member may update (accept transition only).
      // SCENARIO-132: requester self-accept blocked.
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.members
                    && request.auth.uid != resource.data.requesterId
                    && request.resource.data.status == 'accepted'
                    && request.resource.data.requesterId == resource.data.requesterId
                    && request.resource.data.members == resource.data.members;

      // Delete: either member may remove the friendship.
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.members;
    }
  }
}
