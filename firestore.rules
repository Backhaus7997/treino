rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      // Owner-only read.
      allow read: if request.auth != null
                  && request.auth.uid == uid;

      // Create: only the authenticated user can create their own doc, uid MUST
      // match doc id, and self-registration is ALWAYS 'athlete'. The 'trainer'
      // role is intrinsic (AGENTS.md rule 3) and provisioned exclusively via the
      // Admin SDK, which bypasses these rules — so the client must never be able
      // to mint a trainer. QA-SEC-001: allowing role in ['athlete','trainer']
      // here let any client self-assign trainer (privilege escalation) and, since
      // update pins role immutable, it was permanent.
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.role == 'athlete';

      // Update: only the owner can update, and the four immutable fields
      // MUST equal their previous values. Trainers via Admin SDK only;
      // email changes via FirebaseAuth re-verification flow.
      //
      // Paywall Fase 7 PR1 (design §5.1): `subscription` (whole map) and
      // `weightedLoad` are CF-write-only. Follows the `payments` field-pin
      // idiom (firestore.rules ~1112-1134) — pinned equal-to-existing via
      // get(...,null) so absence on both sides is a no-op match. The owner
      // can still freely update every OTHER field on their own doc; only
      // these two paywall fields are locked out. Admin SDK (CFs) bypass
      // rules entirely, so createPreapproval/mpWebhook/downgrade/reactivation
      // CFs write them normally.
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    // uid: identity — must equal doc id forever.
                    && request.resource.data.uid == resource.data.uid
                    // role: AGENTS.md rule 3 — intrinsic, never client-mutable.
                    && request.resource.data.role == resource.data.role
                    // email: must use FirebaseAuth.updateEmail re-verification.
                    && request.resource.data.email == resource.data.email
                    // createdAt: audit field — preserves analytics integrity.
                    && request.resource.data.createdAt == resource.data.createdAt
                    // subscription/weightedLoad: CF-write-only (paywall Fase 7).
                    && request.resource.data.get('subscription', null) == resource.data.get('subscription', null)
                    && request.resource.data.get('weightedLoad', null) == resource.data.get('weightedLoad', null);

      // Delete denied — account deletion goes through privileged Cloud Function.
      allow delete: if false;
    }

    match /exercises/{exerciseId} {
      // Catálogo público para usuarios autenticados.
      allow read: if request.auth != null;
      // Catálogo writeable solo via Admin SDK (seed script).
      allow write: if false;
    }

    match /routines/{routineId} {
      // Read: público para autenticados si la rutina es `visibility: 'public'`
      // (default histórico — todas las plantillas seedeadas sin el campo
      // explícito caen en este branch). Si la rutina es privada
      // (`visibility: 'private'`), solo `assignedBy` (PF) o `assignedTo`
      // (atleta) pueden leerla. REQ-COACH-FOUNDATIONS-006.
      //
      // ⚠️  `resource == null` NO es opcional — es el guard de existencia.
      // En un `get` sobre un doc INEXISTENTE, `resource` es null, y cualquier
      // desreferencia de `resource.data` (p. ej. `'visibility' in resource.data`)
      // hace fallar la EVALUACIÓN de la regla → la lectura vuelve como
      // PERMISSION_DENIED, no como un snapshot vacío. Sin este short-circuit,
      // `getById()` de una rutina borrada TIRA EXCEPCIÓN en vez de devolver
      // null, y el `if (!snap.exists)` del cliente es código muerto que nunca
      // se ejecuta. Eso rompió los radares de distribución muscular: una sola
      // sesión vieja apuntando a una rutina borrada dejaba el gráfico entero
      // en blanco.
      // El único dato que expone es "este id no existe" vs "existe pero es
      // privado" — los auto-ids de Firestore son de 20 chars aleatorios, así
      // que no habilita enumeración.
      // Sólo aplica a `get`: en un `list` (query) `resource` es cada doc
      // candidato y nunca es null, así que las queries no se ven afectadas.
      allow read: if request.auth != null
                  && (resource == null
                      || !('visibility' in resource.data)
                      || resource.data.visibility == 'public'
                      || resource.data.visibility == 'shared'
                      || request.auth.uid == resource.data.assignedTo
                      || request.auth.uid == resource.data.assignedBy
                      || request.auth.uid == resource.data.createdBy // REQ-USR-008, SCENARIO-605
                      // Trainer-public templates: any authenticated user
                      // can read a `trainer-template` doc IF the owning
                      // trainer flipped `sharedTemplatesWithAthletes` on
                      // their public profile. The athlete client filters
                      // results by their linked trainer's uid; non-linked
                      // users could technically query but it's the same
                      // privacy model as the public system catalogue.
                      || (resource.data.source == 'trainer-template'
                          && get(/databases/$(database)/documents/userPublicProfiles/$(resource.data.assignedBy)).data.sharedTemplatesWithAthletes == true));

      // CREATE branch 1: trainer-assigned + trainer-template.
      // - assignedBy debe coincidir con el uid del caller (anti-spoofing).
      // - assignedBy debe coincidir con el uid del caller (anti-spoofing).
      // - source debe ser 'trainer-assigned' (no system, no user).
      // - visibility debe ser 'private' o 'shared' (no 'public').
      // - assignedTo debe ser un string no vacío (uid del atleta destino).
      // REQ-COACH-PLANS-005..010, SCENARIO-438..443.
      allow create: if request.auth != null
                    && request.resource.data.assignedBy == request.auth.uid
                    && (
                      // Trainer-assigned plan for a specific athlete.
                      (request.resource.data.source == 'trainer-assigned'
                        && request.resource.data.visibility in ['private', 'shared']
                        && request.resource.data.assignedTo is string
                        && request.resource.data.assignedTo.size() > 0)
                      ||
                      // Trainer template — no athlete assigned. Owner-only
                      // read is already covered by the read rule via the
                      // `assignedBy == uid` branch. json_serializable emits
                      // `'assignedTo': null` literally (the field is present
                      // with null value), so we compare against null directly
                      // — `.get('assignedTo', '')` would return null (not the
                      // default '') because the key DOES exist.
                      (request.resource.data.source == 'trainer-template'
                        && request.resource.data.visibility == 'private'
                        && request.resource.data.assignedTo == null)
                    );

      // CREATE branch 2 (NEW): athlete self-authored — 6 conditions, all must pass.
      // REQ-USR-004, REQ-USR-009, REQ-USR-012, REQ-USR-014, ADR-USR-03, ADR-USR-06.
      // SCENARIO-600..604.
      //
      // Visibility clamped to {'private', 'public'} — the athlete may opt in
      // at create time to share the routine on their public profile. `shared`
      // stays trainer-assigned only (that path is branch 1 above).
      allow create: if request.auth != null
                    && request.resource.data.source == 'user-created'
                    && request.resource.data.createdBy == request.auth.uid   // anti-spoofing (REQ-USR-014)
                    && request.resource.data.visibility in ['private', 'public']
                    && !('assignedBy' in request.resource.data)              // must be absent (REQ-USR-004)
                    && !('assignedTo' in request.resource.data)              // must be absent (REQ-USR-004)
                    && request.resource.data.createdAt is timestamp;

      // UPDATE path 1 (narrow): owner flips only `status` — archive / restore.
      // REQ-USR-013, SCENARIO-607, SCENARIO-608.
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.createdBy
                    && resource.data.source == 'user-created'
                    && request.resource.data.diff(resource.data).affectedKeys()
                         == ['status'].toSet()
                    && request.resource.data.status in ['active', 'archived'];

      // UPDATE path 2: owner edits content fields (name, level, days).
      // REQ-USR-018, ADR-USR-03.
      //
      // Invariants enforced server-side (mirrors client guards in
      // RoutineRepository.updateUserOwned and the create rule):
      //   - Only the owner (createdBy == auth.uid) may update.
      //   - source must remain 'user-created' (cannot escalate to system/trainer).
      //   - createdBy must not change (immutable owner identity).
      //   - visibility MAY change between 'private' and 'public' (REQ-USR-012
      //     reopened to support the "share to my public profile" feature —
      //     Instagram-style retroactive visibility toggle). The value must
      //     stay in {'private', 'public'}; 'shared' is trainer-assigned only.
      //   - createdAt must not change (audit field, immutable post-create).
      //   - assignedBy and assignedTo must be absent — user-created routines
      //     must never acquire trainer-assignment fields via a client write.
      //   - Only 'name', 'level', 'days', 'numWeeks', 'visibility' are the
      //     allowed mutable content keys (plus any subset). The payload must
      //     not contain keys outside the full known field set (hasOnly guard).
      //
      // ⚠️  COUPLING WARNING — hasOnly field list below:
      // This list MUST contain every field a user-created routine doc stores.
      // If you add a field to the Routine model, createUserOwned, or
      // updateUserOwned, you MUST add it here too — otherwise ALL athlete
      // routine updates will fail with permission-denied.
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.createdBy
                    && resource.data.source == 'user-created'
                    // Immutable identity fields must not change.
                    && request.resource.data.createdBy == resource.data.createdBy
                    && request.resource.data.source == resource.data.source
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.status == resource.data.status
                    // Visibility may toggle but only within the owner-safe set.
                    && request.resource.data.visibility in ['private', 'public']
                    // Trainer-assignment fields must be absent (anti-hijack).
                    && !('assignedBy' in request.resource.data)
                    && !('assignedTo' in request.resource.data)
                    // Only content fields may appear in the written document.
                    && request.resource.data.keys().hasOnly(
                         // + numWeeks (periodization, Model B) — mirror RoutineRepository.
                         ['name', 'level', 'days',
                          'source', 'createdBy', 'visibility', 'createdAt', 'status',
                          'split', 'estimatedMinutesPerDay', 'imageUrl', 'numWeeks'])
                    // The diff must touch ONLY content fields (name/level/days/
                    // numWeeks/visibility).
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['name', 'level', 'days', 'numWeeks', 'visibility']);

      // UPDATE path 3: trainer edits content of a trainer-assigned plan.
      //
      // Invariants enforced server-side (mirrors client guards in
      // RoutineRepository.updateAssigned):
      //   - Only the assigning trainer (assignedBy == auth.uid) may update.
      //   - source must remain 'trainer-assigned'.
      //   - assignedBy must not change (immutable trainer identity).
      //   - assignedTo must not change (immutable athlete assignment).
      //   - createdBy must not change.
      //   - createdAt must not change (audit field).
      //   - Only 'name', 'split', 'level', 'days' are the allowed mutable
      //     content keys. The diff must touch only those fields.
      //   - The payload must not contain keys outside the full known field
      //     set (hasOnly guard).
      //
      // ⚠️  COUPLING WARNING — hasOnly field list below:
      // This list MUST contain every field a trainer-assigned routine doc
      // stores. If you add a field to the Routine model, createAssigned, or
      // updateAssigned, you MUST add it here too — otherwise ALL trainer plan
      // updates will fail with permission-denied.
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.assignedBy
                    && resource.data.source == 'trainer-assigned'
                    // Immutable identity fields must not change.
                    && request.resource.data.assignedBy == resource.data.assignedBy
                    && request.resource.data.assignedTo == resource.data.assignedTo
                    && request.resource.data.source == resource.data.source
                    && (!('createdBy' in resource.data)
                        || request.resource.data.createdBy == resource.data.createdBy)
                    && (!('createdAt' in resource.data)
                        || request.resource.data.createdAt == resource.data.createdAt)
                    // Only content fields may appear in the written document.
                    && request.resource.data.keys().hasOnly(
                         // + numWeeks (periodization, Model B) — mirror RoutineRepository.
                         ['name', 'split', 'level', 'days',
                          'source', 'assignedBy', 'assignedTo', 'visibility',
                          'status', 'createdBy', 'createdAt',
                          'estimatedMinutesPerDay', 'imageUrl', 'numWeeks'])
                    // The diff must touch ONLY content fields.
                    && request.resource.data.diff(resource.data).affectedKeys()
                         // + numWeeks (periodization) — repo always sends it.
                         .hasOnly(['name', 'split', 'level', 'days', 'numWeeks']);

      // UPDATE path 4: trainer edits content of a trainer template.
      //
      // Invariants enforced server-side (mirrors client guards in
      // RoutineRepository.updateTemplate):
      //   - Only the owning trainer (assignedBy == auth.uid) may update.
      //   - source must remain 'trainer-template'.
      //   - assignedBy must not change (immutable trainer identity).
      //   - assignedTo must remain null (templates have no assigned athlete).
      //   - createdBy must not change.
      //   - createdAt must not change (audit field).
      //   - Only 'name', 'split', 'level', 'days' are the allowed mutable
      //     content keys. The diff must touch only those fields.
      //   - The payload must not contain keys outside the full known field
      //     set (hasOnly guard).
      //
      // ⚠️  COUPLING WARNING — hasOnly field list below:
      // This list MUST contain every field a trainer-template routine doc
      // stores. If you add a field to the Routine model, createTemplate, or
      // updateTemplate, you MUST add it here too — otherwise ALL trainer
      // template updates will fail with permission-denied.
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.assignedBy
                    && resource.data.source == 'trainer-template'
                    // Immutable identity fields must not change.
                    && request.resource.data.assignedBy == resource.data.assignedBy
                    && request.resource.data.assignedTo == null
                    && request.resource.data.source == resource.data.source
                    && (!('createdBy' in resource.data)
                        || request.resource.data.createdBy == resource.data.createdBy)
                    && (!('createdAt' in resource.data)
                        || request.resource.data.createdAt == resource.data.createdAt)
                    // Only content fields may appear in the written document.
                    && request.resource.data.keys().hasOnly(
                         // + numWeeks (periodization, Model B) — mirror RoutineRepository.
                         ['name', 'split', 'level', 'days',
                          'source', 'assignedBy', 'assignedTo', 'visibility',
                          'status', 'createdBy', 'createdAt',
                          'estimatedMinutesPerDay', 'imageUrl', 'numWeeks'])
                    // The diff must touch ONLY content fields.
                    && request.resource.data.diff(resource.data).affectedKeys()
                         // + numWeeks (periodization) — repo always sends it.
                         .hasOnly(['name', 'split', 'level', 'days', 'numWeeks']);

      // DELETE (narrow): the owning trainer may delete their OWN
      // `trainer-template` docs (library cleanup) and `trainer-assigned`
      // plans (manually remove a plan from an athlete). User/system routines
      // remain undeletable, and the athlete (assignedTo) cannot delete.
      allow delete: if request.auth != null
                    && resource.data.source in ['trainer-template', 'trainer-assigned']
                    && request.auth.uid == resource.data.assignedBy;
    }

    // Vínculo PF ↔ atleta (Fase 5 Etapa 1, REQ-COACH-FOUNDATIONS-004).
    // Doc id auto-generado. Permite múltiples vínculos históricos por par.
    match /trainer_links/{linkId} {
      // Read: solo members (trainer o athlete del vínculo) o doc inexistente.
      // El branch `resource == null` permite getByPair queries que no
      // matchean leak-free.
      allow read: if request.auth != null
                  && (resource == null
                      || request.auth.uid == resource.data.trainerId
                      || request.auth.uid == resource.data.athleteId);

      // Create: solo el atleta inicia un request (convención producto).
      // Status inicial debe ser `pending`. trainerId != athleteId.
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.athleteId
                    && request.auth.uid != request.resource.data.trainerId
                    && request.resource.data.status == 'pending'
                    && request.resource.data.trainerId is string
                    && request.resource.data.trainerId.size() > 0;

      // Update: members del vínculo pueden actualizar (accept / decline /
      // terminate). Fields `trainerId`, `athleteId`, `requestedAt` son
      // inmutables. Business rules (transiciones de status válidas, who
      // can accept vs terminate) se enforce client-side en el repository;
      // las rules dan defensa estructural.
      //
      // Privacy gate (REQ-COACH-LINK-012..014): el último OR clause restringe
      // la mutación de `sharedWithTrainer` exclusivamente al atleta. Si el
      // request cambia el campo (`request.resource.data.sharedWithTrainer !=
      // resource.data.sharedWithTrainer`), el auth.uid debe ser el atleta.
      // El PF nunca puede flippear el flag.
      //
      // Paywall Fase 7 PR1 (design §5.2, entitlement half only): `entitlement`,
      // `blockedAt`, `blockedReason` son CF-write-only — pinneados
      // equal-to-existing via get(...,null) (mismo idioma que `payments`,
      // firestore.rules ~1112-1134). Solo el downgrade CF y
      // acceptTrainerLink/reactivation CF (Admin SDK, bypasea rules) los
      // escriben. El lock CF-only de promoción status (reemplazar el accept()
      // client-side por el acceptTrainerLink CF) queda para PR4 — hacerlo acá
      // rompería el accept() actual antes de que su reemplazo exista. NOTA
      // QA-SEC-002 (abajo): eso NO impide el gate más angosto que sí agregamos —
      // impedir que el ATLETA promueva el link a active/paused — que preserva el
      // accept() del trainer y no depende del CF.
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.trainerId
                        || request.auth.uid == resource.data.athleteId)
                    // QA-SEC-002: only the trainer may promote a link INTO a
                    // reviewable state (active/paused). The athlete creates the
                    // pending request and may terminate it, but must never
                    // self-promote — otherwise it forges an active/paused link
                    // and fabricates reviews against any trainer (reviews create
                    // gates on link.status in ['active','paused']). The trainer's
                    // accept()/pause()/resume() still work; the acceptTrainerLink
                    // CF (Admin SDK) bypasses rules. This is narrower than the
                    // CF-only pending→active lock deferred to PR4: it preserves
                    // the current client accept() (performed by the trainer), so
                    // it does not break that flow ahead of the CF.
                    && (request.resource.data.status == resource.data.status
                        || !(request.resource.data.status in ['active', 'paused'])
                        || request.auth.uid == resource.data.trainerId)
                    && request.resource.data.trainerId == resource.data.trainerId
                    && request.resource.data.athleteId == resource.data.athleteId
                    && request.resource.data.requestedAt == resource.data.requestedAt
                    && (request.resource.data.sharedWithTrainer == resource.data.sharedWithTrainer
                        || request.auth.uid == resource.data.athleteId)
                    && request.resource.data.get('entitlement', null) == resource.data.get('entitlement', null)
                    && request.resource.data.get('blockedAt', null) == resource.data.get('blockedAt', null)
                    && request.resource.data.get('blockedReason', null) == resource.data.get('blockedReason', null);

      // Delete denegado — terminate vía update status='terminated'.
      allow delete: if false;
    }

    match /posts/{postId} {
      // QA-FEED-001: post privacy is enforced SERVER-SIDE (was client-side only,
      // REQ-PFM-009 — any authenticated user could read every post via the SDK).
      // A post is readable when it is public, is the caller's own, is a
      // 'friends' post authored by an ACCEPTED friend, or is a 'gym' post whose
      // authorGymId matches the caller's gym. The client feed queries are
      // already scoped to match (feedForFriends by friend uids, feedForGym by
      // gym, profile by privacy tier), so these per-doc get()s only fire for
      // rows the query already narrowed to.
      function postFriendAccepted(authorUid) {
        let fid = request.auth.uid < authorUid
          ? request.auth.uid + '_' + authorUid
          : authorUid + '_' + request.auth.uid;
        return exists(/databases/$(database)/documents/friendships/$(fid))
            && get(/databases/$(database)/documents/friendships/$(fid)).data.status == 'accepted';
      }
      function postSameGym(authorGymId) {
        return authorGymId != null
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.gymId == authorGymId;
      }

      allow read: if request.auth != null
                  && (
                    resource == null
                    || resource.data.privacy == 'public'
                    || request.auth.uid == resource.data.authorUid
                    || (resource.data.privacy == 'friends'
                        && postFriendAccepted(resource.data.authorUid))
                    || (resource.data.privacy == 'gym'
                        && postSameGym(resource.data.get('authorGymId', null)))
                  );

      // Create: only the owner of the post — authorUid must equal caller uid.
      // SCENARIO-130: non-owner create is blocked.
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.authorUid;

      // Update and delete: only the original author.
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.authorUid;
    }

    // Public identity documents — one per user, public-readable by any
    // authenticated user, writable only by the owner. Contains ONLY the 15
    // known fields (uid, displayName, displayNameLowercase, avatarUrl,
    // gymId, gymName, workoutsCount, racha, followersCount, followingCount,
    // sharedTemplatesWithAthletes, rankingOptIn, lifetimeVolumeKg,
    // bestSquatKg, bestBenchKg, bestDeadliftKg).
    // REQ-UPP-014, REQ-UPP-015. GAP-1, GAP-2, GAP-3 from design Section C.
    //
    // rankings-integrity Phase 2 (PR#2) hardening — AD-3, AD-4, AD-6, AD-8:
    //   - Field allowlist via keys().hasOnly() (was previously unchecked).
    //   - gymId cross-doc pin against users/{uid}.gymId (an athlete cannot
    //     self-assign to a gym they don't attend).
    //   - The 4 ranking-metric fields (lifetimeVolumeKg, bestSquatKg,
    //     bestBenchKg, bestDeadliftKg) become CF-write-only: a client update
    //     may only re-assert the currently stored value, EXCEPT on the
    //     rankingOptIn true->false disable transition, where
    //     clearRankingMetrics is explicitly allowed to reset them to their
    //     fixed defaults (spec gym-rankings: Opt-In Disable — Unchanged,
    //     Client-Initiated — "deflating one's own stats is not a forgery
    //     vector"). The server-side recompute trigger
    //     (functions/src/ranking-aggregate.ts) writes via the Admin SDK,
    //     which bypasses rule evaluation entirely — no rule path here
    //     "allows" that write, it is simply not subject to rules.
    //   - Type/range validation (AD-8): best*Kg <= 1000, lifetimeVolumeKg
    //     <= 100_000_000 when present; rankingOptIn must be bool when
    //     present. Bounds are defense-in-depth — the trigger is the real
    //     authority on the true value.
    match /userPublicProfiles/{uid} {
      // Any authenticated user can read (get or list). Enables prefix-range
      // search queries from searchByDisplayName. REQ-UPP-014. Unchanged by
      // this hardening pass (Read Access Unchanged).
      allow read: if request.auth != null;

      // Only the owner can create their own doc; uid in body must match doc
      // id. Field allowlist applies from create onward. gymId, when
      // present, must match the athlete's own private gymId (AD-4). The 4
      // ranking-metric fields must be absent or at their fixed defaults —
      // a create cannot seed forged values (AD-3).
      //
      // ⚠️  getAfter(), not get(): UserRepository.update dual-writes
      // users/{uid} and userPublicProfiles/{uid} in a SINGLE WriteBatch
      // (e.g. profile_gym_screen's gym-change flow, RankingOptInController's
      // gymId denormalization). Firestore rules' get() only ever sees the
      // PRE-batch committed state — it cannot observe another write in the
      // same batch — so pinning against get(users/{uid}) would deny every
      // real same-batch gym change (the private doc's new value isn't
      // visible yet when this doc's rule evaluates). getAfter() reads the
      // POST-batch value instead, which is exactly what a same-batch
      // dual-write needs to validate against. Note: users/{uid}.gymId is
      // itself unrestricted/self-reported (see match /users/{uid} above —
      // no gym-membership authority exists in this system), so this pin's
      // real guarantee is narrower than "proves gym attendance": it only
      // enforces that the PUBLIC gymId is consistent with whatever the
      // athlete's OWN private doc claims, closing the "show gym B publicly
      // while privately tied to gym A" inconsistency — not a physical-
      // attendance proof, which no rule can provide given gymId is
      // self-reported everywhere.
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.keys().hasOnly([
                         'uid', 'displayName', 'displayNameLowercase',
                         'avatarUrl', 'gymId', 'gymName', 'workoutsCount',
                         'racha', 'followersCount', 'followingCount',
                         'sharedTemplatesWithAthletes', 'rankingOptIn',
                         'lifetimeVolumeKg', 'bestSquatKg', 'bestBenchKg',
                         'bestDeadliftKg'
                       ])
                    && (!('gymId' in request.resource.data)
                        || request.resource.data.gymId
                           == getAfter(/databases/$(database)/documents/users/$(uid)).data.gymId)
                    && (!('lifetimeVolumeKg' in request.resource.data)
                        || request.resource.data.lifetimeVolumeKg == 0)
                    && (!('bestSquatKg' in request.resource.data)
                        || request.resource.data.bestSquatKg == null)
                    && (!('bestBenchKg' in request.resource.data)
                        || request.resource.data.bestBenchKg == null)
                    && (!('bestDeadliftKg' in request.resource.data)
                        || request.resource.data.bestDeadliftKg == null)
                    && (!('rankingOptIn' in request.resource.data)
                        || request.resource.data.rankingOptIn is bool);

      // Only the owner can update; uid in body must not change (immutable).
      // Field allowlist, gymId pin, CF-write-only metric pins, and
      // type/range validation all apply here.
      //
      // ⚠️  COUPLING WARNING — hasOnly field list below:
      // This list MUST contain every field a userPublicProfiles doc stores.
      // If you add a field to UserPublicProfile, you MUST add it here too —
      // otherwise ALL profile updates will fail with permission-denied.
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.keys().hasOnly([
                         'uid', 'displayName', 'displayNameLowercase',
                         'avatarUrl', 'gymId', 'gymName', 'workoutsCount',
                         'racha', 'followersCount', 'followingCount',
                         'sharedTemplatesWithAthletes', 'rankingOptIn',
                         'lifetimeVolumeKg', 'bestSquatKg', 'bestBenchKg',
                         'bestDeadliftKg'
                       ])
                    // gymId Integrity (AD-4): when the write touches gymId,
                    // it must equal the athlete's own private gymId.
                    // getAfter(), not get() — see the create-branch comment
                    // above: UserRepository.update dual-writes users/{uid}
                    // and userPublicProfiles/{uid} in the SAME WriteBatch,
                    // and get() cannot see a sibling write from that same
                    // batch (it only sees pre-batch state). getAfter() reads
                    // the post-batch value, so a same-batch gym change
                    // (profile_gym_screen, RankingOptInController) is
                    // correctly validated instead of being denied by a
                    // stale pre-batch comparison. A missing/absent
                    // users/{uid} doc makes getAfter() fail the whole
                    // expression (denied) — onboarding always writes
                    // users/{uid} in the same or an earlier batch, so this
                    // is safe in the normal write order.
                    && (!('gymId' in request.resource.data)
                        || request.resource.data.gymId
                           == getAfter(/databases/$(database)/documents/users/$(uid)).data.gymId)
                    // rankingOptIn: bool when present (Type Validation).
                    && (!('rankingOptIn' in request.resource.data)
                        || request.resource.data.rankingOptIn is bool)
                    // CF-Write-Only Ranking Metrics (AD-3) + Opt-In Disable
                    // exception (gym-rankings spec, AD-6 resolution): each
                    // metric may only (a) be absent from the write, (b)
                    // equal its currently stored value, or (c) be reset to
                    // its fixed default IF this write is also flipping
                    // rankingOptIn from true to false — the exact shape of
                    // UserPublicProfileRepository.clearRankingMetrics. Any
                    // other value is denied — this is not a laundering path
                    // for a forged metric via a disable/re-enable round
                    // trip, since the disable-branch only tolerates the
                    // fixed default, never an arbitrary value.
                    && (!('lifetimeVolumeKg' in request.resource.data)
                        || request.resource.data.lifetimeVolumeKg
                           == resource.data.get('lifetimeVolumeKg', 0)
                        || (request.resource.data.get('rankingOptIn', true) == false
                            && resource.data.get('rankingOptIn', false) == true
                            && request.resource.data.lifetimeVolumeKg == 0))
                    && (!('bestSquatKg' in request.resource.data)
                        || request.resource.data.bestSquatKg
                           == resource.data.get('bestSquatKg', null)
                        || (request.resource.data.get('rankingOptIn', true) == false
                            && resource.data.get('rankingOptIn', false) == true
                            && request.resource.data.bestSquatKg == null))
                    && (!('bestBenchKg' in request.resource.data)
                        || request.resource.data.bestBenchKg
                           == resource.data.get('bestBenchKg', null)
                        || (request.resource.data.get('rankingOptIn', true) == false
                            && resource.data.get('rankingOptIn', false) == true
                            && request.resource.data.bestBenchKg == null))
                    && (!('bestDeadliftKg' in request.resource.data)
                        || request.resource.data.bestDeadliftKg
                           == resource.data.get('bestDeadliftKg', null)
                        || (request.resource.data.get('rankingOptIn', true) == false
                            && resource.data.get('rankingOptIn', false) == true
                            && request.resource.data.bestDeadliftKg == null))
                    // Type/Range Validation (AD-8): defense-in-depth bounds
                    // when a metric is present AND is a fresh (non-pinned,
                    // non-disable-reset) numeric write would already have
                    // been rejected above unless it equals the stored value
                    // or the fixed default — both of which are always within
                    // bounds. These checks guard the stored/reasserted value
                    // itself is well-typed, protecting against a corrupt
                    // stored value some day being re-asserted forever.
                    && (!('lifetimeVolumeKg' in request.resource.data)
                        || (request.resource.data.lifetimeVolumeKg is number
                            && request.resource.data.lifetimeVolumeKg >= 0
                            && request.resource.data.lifetimeVolumeKg <= 100000000))
                    && (!('bestSquatKg' in request.resource.data)
                        || request.resource.data.bestSquatKg == null
                        || (request.resource.data.bestSquatKg is number
                            && request.resource.data.bestSquatKg >= 0
                            && request.resource.data.bestSquatKg <= 1000))
                    && (!('bestBenchKg' in request.resource.data)
                        || request.resource.data.bestBenchKg == null
                        || (request.resource.data.bestBenchKg is number
                            && request.resource.data.bestBenchKg >= 0
                            && request.resource.data.bestBenchKg <= 1000))
                    && (!('bestDeadliftKg' in request.resource.data)
                        || request.resource.data.bestDeadliftKg == null
                        || (request.resource.data.bestDeadliftKg is number
                            && request.resource.data.bestDeadliftKg >= 0
                            && request.resource.data.bestDeadliftKg <= 1000));

      // Deletion denied — managed exclusively through WriteBatch from
      // server-side operations (backfill, account deletion Cloud Function).
      allow delete: if false;
    }

    // Trainer public identity documents — readable by any authenticated user,
    // writable only by the owner (always written via UserRepository dual-write).
    // REQ-COACH-DISC-DATA-008, REQ-COACH-DISC-DATA-009.
    //
    // rules-hardening Slice B (AD-3) — averageRating/reviewCount Are
    // CF-Write-Only: these two fields are derived aggregates written by the
    // `reviewAggregate` Cloud Function via the Admin SDK (which bypasses
    // rules entirely — no rule path here "allows" that write). A client
    // write (create or update) may only (a) omit the fields, or (b) on
    // update, re-assert the exact currently-stored value. Any other value —
    // including seeding a value at create time — is denied. Mirrors the
    // userPublicProfiles CF-write-only ranking-metric idiom
    // (firestore.rules:434-468, `.get(field, null)` null-safe comparison)
    // verbatim, without the opt-in-disable exception clause (no analogous
    // disable flow exists for reviews).
    //
    // Deliberately NO keys().hasOnly() allowlist here (AD-3 divergence from
    // the trainer-reviews spec's "Out-of-allowlist field" scenario — see
    // tasks.md 2.7): TrainerPublicProfileRepository's write path is a
    // partial merge with a large, evolving discovery-field set, making
    // hasOnly a high-risk coupling trap for near-zero security value (those
    // fields are self-attested, not a trust boundary).
    match /trainerPublicProfiles/{uid} {
      // Any authenticated user can read (SCENARIO-416).
      allow read: if request.auth != null;

      // Only the owner can create their own doc; uid in body must match doc id.
      // (SCENARIO-418). averageRating/reviewCount must be absent or null —
      // a create cannot seed a forged starting value (AD-3).
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.get('averageRating', null) == null
                    && request.resource.data.get('reviewCount', null) == null;

      // Only the owner can update; uid in body must not change (SCENARIO-418).
      // averageRating/reviewCount must be absent or unchanged from the
      // stored value (AD-3) — closes the raw set(merge)/update forgery path.
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.get('averageRating', null) == resource.data.get('averageRating', null)
                    && request.resource.data.get('reviewCount', null) == resource.data.get('reviewCount', null);

      // Delete denied — managed exclusively via privileged server-side operations.
      allow delete: if false;
    }

    // Gym catalog — Fase 6 Etapa 0 (multi-location).
    //
    // Cualquier user autenticado puede leer (lo necesitan athletes para
    // mostrar el nombre del gym cuando ven una `TrainerLocation`, y trainers
    // para elegirlo en el form de edición de perfil).
    //
    // Solo PFs (role == trainer) pueden crear via self-service. El doc tiene
    // que setear `source: 'self-service'` y `createdBy: request.auth.uid` —
    // si no, denied. Update/delete denegado del cliente — moderación va por
    // Console o un Cloud Function privilegiado en el futuro.
    //
    // gym-google-places (sdd change) — PLAN B (client-side resolve): the
    // original design routed athlete-originated `google-places` docs through
    // a `resolveGymPlace` Cloud Function (Admin SDK, bypasses rules). That CF
    // CANNOT be deployed — GCP project `treino-dev` sits under org
    // `code-assurance.com`, whose Domain-Restricted-Sharing policy blocks a
    // publicly-invokable (`allUsers`) Cloud Function. The CF is SHELVED
    // (kept in functions/src/places-search.ts, not exported from index.ts).
    // Resolution now happens CLIENT-SIDE (ResolveGymPlaceService,
    // lib/features/gyms/data/resolve_gym_place_service.dart), so an
    // authenticated athlete's client now writes `gyms/{placeId}` directly —
    // this ADDS a second `allow create` branch below for that path. The
    // shape is intentionally narrow: `source` must be exactly
    // 'google-places', `id` must equal the doc id (placeId), and no
    // `createdBy`/trainer-role check applies (any authenticated user, not
    // just trainers, can resolve a gym place). The pre-existing
    // self-service branch (trainer-only) is unchanged.
    match /gyms/{gymId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'trainer'
                    && request.resource.data.source == 'self-service'
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.keys().hasAll(['name', 'lat', 'lng', 'geohash', 'source', 'createdBy', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 100
                    // QA-SEC-003: geographic range guard (mirrors the
                    // google-places create branch) — coordinates must be valid.
                    && request.resource.data.lat is number
                    && request.resource.data.lat >= -90
                    && request.resource.data.lat <= 90
                    && request.resource.data.lng is number
                    && request.resource.data.lng >= -180
                    && request.resource.data.lng <= 180
                    && request.resource.data.geohash is string;

      allow create: if request.auth != null
                    && request.resource.data.source == 'google-places'
                    && request.resource.data.id == gymId
                    && request.resource.data.keys().hasAll(['id', 'name', 'lat', 'lng', 'source'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 100
                    // QA-SEC-003: geographic range guard — a resolved place must
                    // land on Earth. Blocks garbage coordinates polluting the
                    // world-readable catalog / distance math.
                    && request.resource.data.lat is number
                    && request.resource.data.lat >= -90
                    && request.resource.data.lat <= 90
                    && request.resource.data.lng is number
                    && request.resource.data.lng >= -180
                    && request.resource.data.lng <= 180;

      // Client-side resolve can race two concurrent selectors of the same
      // never-before-seen placeId; the read-through cache in
      // ResolveGymPlaceService only calls upsert() on a cache miss, so the
      // ONLY legitimate update is that race re-upserting the SAME Place
      // Details for an already-resolved placeId.
      //
      // QA-SEC-003: `gyms` is world-readable and drives gym association and
      // leaderboards, so the resolved identity fields MUST be pinned to their
      // existing values. The previous type-only check let ANY authenticated
      // user overwrite name/lat/lng of any existing gym — catalog vandalism.
      // Pinning name/lat/lng/source/id equal-to-existing still lets the
      // same-shape race write through (identical values are a no-op match)
      // while denying every value change. Mirrors the field-pin idiom used by
      // userPublicProfiles ranking metrics and trainerPublicProfiles
      // averageRating/reviewCount above.
      allow update: if request.auth != null
                    && resource.data.source == 'google-places'
                    && request.resource.data.source == resource.data.source
                    && request.resource.data.id == gymId
                    && request.resource.data.name == resource.data.name
                    && request.resource.data.lat == resource.data.lat
                    && request.resource.data.lng == resource.data.lng;

      allow delete: if false;
    }

    match /friendships/{friendshipId} {
      // Read: only members of the friendship — OR doc does not exist (returns
      // empty snapshot without leaking data). The `resource == null` branch is
      // required for `getByPair()` to gracefully resolve "no friendship yet"
      // between two users who have never interacted (e.g. fresh public profile
      // visits). Discovered during user-public-profiles smoke test;
      // pre-existing from PR #28 friendships introduction (REQ-PFM-010).
      allow read: if request.auth != null
                  && (resource == null
                      || request.auth.uid in resource.data.members);

      // Create: only by the requester, requester in members. Status may be:
      //   - 'pending' (default flow; owner of the target profile must accept)
      //   - 'accepted' ONLY IF the target user's public profile has
      //     `isProfilePublic` truthy at write time (Instagram-style public
      //     account: no approval required). Enforced via a get() lookup on
      //     `userPublicProfiles/{otherUid}`.
      //
      // IMPORTANT: pre-existing profile docs written before the privacy
      // feature landed do NOT have the `isProfilePublic` field. We treat a
      // missing field as `true` (public by default — matches
      // `UserPublicProfile.isProfilePublic` freezed default) via
      // `.get('isProfilePublic', true)`. Without this fallback every legacy
      // account would fail auto-accept even though its owner never opted out.
      //
      // NOTE on rule cost: the `get()` in the accepted branch runs only when
      // the client tries to auto-accept. The pending branch (majority path)
      // stays free of extra reads.
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.requesterId
                    && request.auth.uid in request.resource.data.members
                    && (
                      request.resource.data.status == 'pending'
                      ||
                      (request.resource.data.status == 'accepted'
                        // The "other" member is whichever of uidA/uidB
                        // isn't the requester. Instead of computing it,
                        // just check that ONE of the two members has a
                        // public profile AND isn't the requester itself.
                        && (
                          (request.resource.data.uidA != request.auth.uid
                            && get(/databases/$(database)/documents/userPublicProfiles/$(request.resource.data.uidA)).data.get('isProfilePublic', true) == true)
                          ||
                          (request.resource.data.uidB != request.auth.uid
                            && get(/databases/$(database)/documents/userPublicProfiles/$(request.resource.data.uidB)).data.get('isProfilePublic', true) == true)
                        )
                      )
                    );

      // Update: only the non-requester member may update (accept transition only).
      // SCENARIO-132: requester self-accept blocked.
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.members
                    && request.auth.uid != resource.data.requesterId
                    && request.resource.data.status == 'accepted'
                    && request.resource.data.requesterId == resource.data.requesterId
                    && request.resource.data.members == resource.data.members;

      // Delete: either member may remove the friendship.
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.members;
    }

    // Chat 1-1 entre PF y athlete (Fase 5 Etapa 5).
    // Doc id determinístico: sortedUids.join('_'). Reglas:
    //   - read: solo members del chat (o doc inexistente para tolerar reads
    //     desde getOrCreate antes del create).
    //   - create: caller en members, members.size()==2, members ordenados
    //     ascendentemente, y chatId == members.join('_').
    //   - update: caller en members. members/createdAt inmutables.
    //   - delete: denied.
    match /chats/{chatId} {
      // QA-CHAT-004: a chat may only be opened between two users who have a real
      // relationship — an ACCEPTED friendship (its doc id equals the chatId), or
      // an active trainer_link named by a client-provided `linkId` whose
      // trainerId+athleteId are exactly the two chat members. The link is
      // verified here (not trusted): SEC-002 guarantees an active link is
      // trainer-accepted, so neither party can forge one. Without this gate any
      // authenticated user could open a chat with — and message — anyone.
      function chatRelationshipOk(chatId, members, data) {
        return (
          exists(/databases/$(database)/documents/friendships/$(chatId))
          && get(/databases/$(database)/documents/friendships/$(chatId)).data.status == 'accepted'
        ) || (
          'linkId' in data
          && exists(/databases/$(database)/documents/trainer_links/$(data.linkId))
          && get(/databases/$(database)/documents/trainer_links/$(data.linkId)).data.status == 'active'
          && get(/databases/$(database)/documents/trainer_links/$(data.linkId)).data.trainerId in members
          && get(/databases/$(database)/documents/trainer_links/$(data.linkId)).data.athleteId in members
        );
      }

      allow read: if request.auth != null
                  && (resource == null
                      || request.auth.uid in resource.data.members);

      allow create: if request.auth != null
                    && request.resource.data.members.size() == 2
                    && request.auth.uid in request.resource.data.members
                    && request.resource.data.members[0] < request.resource.data.members[1]
                    && chatId == request.resource.data.members[0] + '_' + request.resource.data.members[1]
                    && chatRelationshipOk(
                        chatId, request.resource.data.members, request.resource.data);

      // REQ-CHATUNREAD-008: members may update the chat (preview fields on
      // send) but a member may only touch THEIR OWN key inside lastRead — a
      // user cannot forge/clear another member's read state. members and
      // createdAt remain immutable. get('lastRead', {}) is null-safe for
      // legacy docs that predate the field.
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.members
                    && request.resource.data.members == resource.data.members
                    && request.resource.data.createdAt == resource.data.createdAt
                    && (
                         !request.resource.data.keys().hasAny(['lastRead'])
                         || request.resource.data.get('lastRead', {})
                              .diff(resource.data.get('lastRead', {}))
                              .affectedKeys()
                              .hasOnly([request.auth.uid])
                       );

      allow delete: if false;

      // Messages sub-collection. Mensajes inmutables en MVP — sin edit/delete.
      // read/create gated por members del chat parent.
      match /messages/{messageId} {
        allow read: if request.auth != null
                    && request.auth.uid in
                        get(/databases/$(database)/documents/chats/$(chatId)).data.members;

        // REQ-CHATMEDIA-006: validity is OR-based — text OR (mediaUrl + mediaType).
        // A message is valid if it carries non-empty text OR a mediaUrl string
        // together with a mediaType string (e.g. 'image' / 'video').
        // senderId, membership, and createdAt checks are unchanged.
        allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.senderId
                      && request.auth.uid in
                          get(/databases/$(database)/documents/chats/$(chatId)).data.members
                      && (
                           (request.resource.data.text is string
                            && request.resource.data.text.size() > 0)
                           ||
                           (request.resource.data.mediaUrl is string
                            && request.resource.data.mediaUrl.size() > 0
                            && request.resource.data.mediaType is string)
                         )
                      && request.resource.data.createdAt is timestamp;

        allow update, delete: if false;
      }
    }

    // Privacy grant: athlete opts in to share their training history with ONE
    // trainer. Doc id == athleteId. The sessions rule reads this via get().
    match /session_shares/{athleteId} {
      allow read: if request.auth != null
                  && (request.auth.uid == athleteId
                      || (resource != null
                          && request.auth.uid == resource.data.trainerId));
      // Only the athlete (owner) may create/update/delete their own grant.
      allow write: if request.auth != null
                   && request.auth.uid == athleteId
                   && (request.resource == null
                       || request.resource.data.trainerId is string);
    }

    // Profile share: athlete opts in to share their personal data (phone,
    // bornAt, heightCm, bodyWeightKg, gender, experienceLevel) with ONE
    // trainer. Doc id == athleteId. Mirrors the session_shares pattern.
    //
    // Slice 1 (web-only groundwork): trainer reads the doc from the Resumen
    // tab. The doc is empty/absent until the athlete opts in via the mobile
    // consent UI (Slice 2 — NOT in this change).
    match /profile_shares/{athleteId} {
      // Athlete reads their own doc; trainer reads when they are the grantee.
      allow read: if request.auth != null
                  && (request.auth.uid == athleteId
                      || (resource != null
                          && request.auth.uid == resource.data.trainerId));
      // Only the athlete may write their own grant doc; trainerId must be a
      // string when the doc is being created or updated (not deleted).
      allow write: if request.auth != null
                   && request.auth.uid == athleteId
                   && (request.resource == null
                       || request.resource.data.trainerId is string);
    }

    // Sessions sub-collection (Fase 4 Etapa 1, REQ-SMS-014).
    // Owner R/W. Trainer granted via session_shares gets read-only access.
    match /users/{uid}/sessions/{sessionId} {
      allow read: if request.auth != null
                  && (request.auth.uid == uid
                      || (exists(/databases/$(database)/documents/session_shares/$(uid))
                          && get(/databases/$(database)/documents/session_shares/$(uid)).data.trainerId == request.auth.uid));
      allow write: if request.auth != null && request.auth.uid == uid;

      // setLogs sub-collection (REQ-SETLOGS-001..004, trainer-athlete-set-logs).
      // Read mirrors parent session-share predicate: owner OR linked trainer.
      // Write is owner-only — trainers (even linked) may never mutate set data.
      // Emulator scenarios: E1 linked reads → allowed; E2 linked lists → allowed;
      // E3 unrelated trainer → denied; E4 no share doc → denied;
      // E5 linked trainer writes → denied; E6 owner reads → allowed;
      // E7 owner writes → allowed; E8 unauthenticated → denied.
      match /setLogs/{setLogId} {
        allow read: if request.auth != null
                    && (request.auth.uid == uid
                        || (exists(/databases/$(database)/documents/session_shares/$(uid))
                            && get(/databases/$(database)/documents/session_shares/$(uid)).data.trainerId == request.auth.uid));
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Daily check-in sub-collection (Fase 4 Etapa 6, REQ-WRC-004).
    // Doc id is the local date key 'YYYY-MM-DD' — one doc per day per user,
    // providing natural dedup. Location-adjacent data: owner-only R/W.
    match /users/{uid}/checkIns/{date} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // Trainer custom exercise library — owner writes, any auth user reads.
    // Each trainer's personal exercise catalogue (names they prefer, video
    // URLs they trust). Hard delete allowed because the routine slots that
    // reference these exercises already denormalize name/group at assign time.
    //
    // Read is auth-only (not owner-only) so an athlete who has a routine
    // referencing a trainer's custom exercise can open its detail screen
    // (video / description). Same privacy stance as the public catalogue
    // and trainer-public templates: an authenticated user could query an
    // exercise if they knew the trainer's uid + exercise id, but the
    // exercise id is auto-generated and only surfaces through routines the
    // user already has access to, so the practical exposure is bounded.
    match /users/{uid}/customExercises/{exId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid;
    }

    // Coach Agenda — availability rules (Fase 5 Etapa 6, REQ-027).
    // Trainers own their rules; athletes and trainers can read any rule
    // (needed to compute free slots client-side). Create/update/delete
    // restricted to the owning trainer.
    // SCENARIOs 525-527 tested via emulator (emulator-deferred per Decision #25).
    match /coach_availability_rules/{ruleId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.trainerId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.trainerId == request.auth.uid;
    }

    // Coach Agenda — availability overrides (Fase 5 Etapa 6, REQ-028).
    // Same ownership model as rules.
    match /coach_availability_overrides/{overrideId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.trainerId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.trainerId == request.auth.uid;
    }

    // Coach Agenda — appointments (Fase 5 Etapa 6, REQ-029, ADR-1, ADR-5).
    // Create: athlete books their own slot (status must be 'confirmed').
    // Update: two valid paths —
    //   Path 1 (cancellation): member cancels with >24h notice.
    //   Path 2 (ADR-1 flip): new athlete flips cancelled → confirmed.
    // Delete: never (audit trail preserved per ADR-1).
    match /appointments/{appointmentId} {
      // Privacy: a member only reads appointments they are part of — their own
      // (athleteId) or the ones they run (trainerId). Closes the prior
      // any-authenticated-user read. Safe now that athlete self-booking (whose
      // transaction `get` read foreign slots) is removed in the read-only model.
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.athleteId
                      || request.auth.uid == resource.data.trainerId);
      // Create: either the athlete books their own slot (legacy self-booking),
      // or the trainer registers a session (new trainer-driven model 2026-06-03).
      //
      // rules-hardening Slice C (AD-1 option b) — Coach-Collection Create
      // Requires Trainer Role: the trainer-create disjunct additionally
      // requires `users/{uid}.role == 'trainer'` so an athlete-role user
      // cannot forge an appointment naming themselves as trainerId against
      // an arbitrary victim athlete. The gate applies ONLY to the trainer
      // disjunct — the legacy athlete self-book disjunct (`athleteId ==
      // auth.uid`) is UNCHANGED, preserving that live path (regression-
      // tested: SCENARIO-CC-08). Role-check only, NOT a trainer_links
      // relationship check — see design.md AD-1 / engram obs #413.
      allow create: if request.auth != null
                    && request.resource.data.status == 'confirmed'
                    && (request.resource.data.athleteId == request.auth.uid
                        || (request.resource.data.trainerId == request.auth.uid
                            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'trainer'));
      // Update has 3 valid paths: cancellation by member, flip cancelled→confirmed,
      // or trainer edits coaching notes.
      allow update: if request.auth != null && (
        // Path 1: cancellation by member with >24h
        (request.resource.data.status == 'cancelled'
         && (request.auth.uid == resource.data.athleteId
             || request.auth.uid == resource.data.trainerId)
         && resource.data.startsAt.toMillis() - 86400000 > request.time.toMillis())
        ||
        // Path 2: flip cancelled→confirmed by new athlete (ADR-1)
        (resource.data.status == 'cancelled'
         && request.resource.data.status == 'confirmed'
         && request.resource.data.athleteId == request.auth.uid)
        ||
        // Path 3: trainer edits coaching notes OR links a Payment on their own
        // appointment (Slice 2a, Agenda→cobro bridge, money-critical).
        // status / athleteId / trainerId / startsAt stay immutable.
        // `paymentId` is SET-ONCE: null → a NON-EMPTY STRING (first bill), or
        // re-assert the SAME value (a notes edit that leaves the charge alone).
        // A client can never overwrite it with a different Payment id, clear it
        // back to null, nor forge an empty / non-string value.
        // NOTE: we deliberately do NOT exists()-check the Payment here —
        // billAppointment creates the Payment and sets paymentId in the SAME
        // Firestore transaction, and rules exists() reads pre-commit state, so
        // an exists() check would reject the legitimate atomic flow.
        (request.auth.uid == resource.data.trainerId
         && request.resource.data.status == resource.data.status
         && request.resource.data.athleteId == resource.data.athleteId
         && request.resource.data.trainerId == resource.data.trainerId
         && request.resource.data.startsAt == resource.data.startsAt
         && ((resource.data.get('paymentId', null) == null
              && request.resource.data.get('paymentId', null) is string
              && request.resource.data.get('paymentId', null).size() > 0)
             || request.resource.data.get('paymentId', null) == resource.data.get('paymentId', null)))
      );
      allow delete: if false;
    }

    // commercialPlans block REMOVED 2026-05-28. The dual pricing model was
    // confusing trainers; pricing now lives ONLY on the trainer's public
    // profile via trainerMonthlyRate. A future subscribe flow may
    // reintroduce a plan catalog with its own rules block.

    // Body measurements / anthropometry. Written by the TRAINER who recorded
    // them (recordedBy) OR self-logged by the athlete about themselves
    // (athlete-self-measurements). The athlete always reads their own; a
    // linked+consented trainer reads the athlete's self-logged ones.
    match /measurements/{measurementId} {
      // READ branches, cheapest first so get()s only run for the trainer path:
      //   1. author (trainer OR self-logging athlete) — pure field compare.
      //   2. subject athlete — own vantage — pure field compare.
      //   3. [athlete-self-measurements] a SELF-LOGGED doc
      //      (recordedBy == athleteId) is readable by a trainer ONLY when BOTH
      //      fixed-path share docs name them: session_shares (live link, kept
      //      by the syncSessionShareOnTrainerLink CF → follows the CURRENT
      //      trainer) AND profile_shares (the athlete's own consent toggle,
      //      the same surface that shares weight/height). Both are keyed by
      //      athleteId, so a trainer's athleteId-scoped list resolves them ONCE
      //      (cached), not per-doc — the same idiom already live for setLogs
      //      (~:852). This is NOT gated on the dead `sharedWithTrainer` bool
      //      (design.md ADR-ASM-2). Ordering is load-bearing: branches 1/2
      //      short-circuit before any get().
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.recordedBy
                      || request.auth.uid == resource.data.athleteId
                      || (resource.data.recordedBy == resource.data.athleteId
                          && exists(/databases/$(database)/documents/session_shares/$(resource.data.athleteId))
                          && get(/databases/$(database)/documents/session_shares/$(resource.data.athleteId)).data.trainerId == request.auth.uid
                          && exists(/databases/$(database)/documents/profile_shares/$(resource.data.athleteId))
                          && get(/databases/$(database)/documents/profile_shares/$(resource.data.athleteId)).data.trainerId == request.auth.uid));
      // CREATE — dual OR-branch (mirrors the appointments athlete-self-book /
      // trainer+role pattern). `recordedBy == uid` + athleteId shape checks are
      // a SHARED precondition of both branches, so a self-logged doc is always
      // recordedBy == athleteId == uid. The `||` short-circuits on the
      // athlete-self branch, so a self-logging athlete never triggers the role
      // get(); a forger naming ANOTHER athleteId always falls through to the
      // role check and is denied (AD-1 forge vector stays closed).
      allow create: if request.auth != null
                    && request.resource.data.recordedBy == request.auth.uid
                    && request.resource.data.athleteId is string
                    && request.resource.data.athleteId.size() > 0
                    && (
                         // Athlete-self branch: may log ONLY about themselves.
                         request.resource.data.athleteId == request.auth.uid
                         // Trainer branch (unchanged from rules-hardening Slice C).
                         || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'trainer'
                       );
      allow update: if request.auth != null
                    && resource.data.recordedBy == request.auth.uid
                    && request.resource.data.recordedBy == resource.data.recordedBy
                    && request.resource.data.athleteId == resource.data.athleteId;
      allow delete: if request.auth != null
                    && resource.data.recordedBy == request.auth.uid;
    }

    // Performance tests / physical assessments. Owned by the TRAINER who recorded
    // them (recordedBy). The athlete gets read-only of their own. No one else.
    match /performance_tests/{testId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.recordedBy
                      || request.auth.uid == resource.data.athleteId);
      // rules-hardening Slice C (AD-1 option b) — Coach-Collection Create
      // Requires Trainer Role: closes the "any athlete-role user forges a
      // performance_test naming themselves recordedBy" vector. Role-check
      // only, NOT a trainer_links relationship check — see design.md AD-1 /
      // engram obs #413.
      allow create: if request.auth != null
                    && request.resource.data.recordedBy == request.auth.uid
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'trainer'
                    && request.resource.data.athleteId is string
                    && request.resource.data.athleteId.size() > 0;
      allow update: if request.auth != null
                    && resource.data.recordedBy == request.auth.uid
                    && request.resource.data.recordedBy == resource.data.recordedBy
                    && request.resource.data.athleteId == resource.data.athleteId;
      allow delete: if request.auth != null
                    && resource.data.recordedBy == request.auth.uid;
    }

    // Per-athlete billing config set by the trainer (Pagos P1).
    // Doc id is deterministic: `${trainerId}_${athleteId}`.
    match /athlete_billing/{docId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.trainerId
                      || request.auth.uid == resource.data.athleteId);
      // rules-hardening Slice C (AD-1 option b) — Coach-Collection Create
      // Requires Trainer Role: closes the "any athlete-role user forges
      // athlete_billing naming themselves trainer" vector. This is a
      // COMBINED create+update rule block, so the role gate is scoped to
      // create-only via `resource == null` (create has no prior resource
      // doc) — legit trainer UPDATES to their existing billing config are
      // unaffected (SCENARIO-CC-06e regression test). Role-check only, NOT
      // a trainer_links relationship check — see design.md AD-1 / engram
      // obs #413.
      allow create, update: if request.auth != null
                  && request.resource.data.trainerId == request.auth.uid
                  && (resource != null
                      || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'trainer')
                  && request.resource.data.athleteId is string
                  && request.resource.data.athleteId.size() > 0;
      allow delete: if request.auth != null && resource.data.trainerId == request.auth.uid;
    }

    // Private per-athlete coaching note written by the trainer. Trainer-only —
    // the athlete cannot read it.
    match /athlete_notes/{docId} {
      // Read: dueño solo (trainer). Si el doc NO existe, `resource == null` y
      // la rule debe permitir la lectura para que el cliente vea "sin nota"
      // en vez de un permission-denied que la UI captura como error. El docId
      // encodea `{trainerId}_{athleteId}` así que un attacker no puede
      // fishearse leyendo docs de otro PF: solo llegaría al doc si armara el
      // par exacto — y si existe, el segundo check bloquea el acceso.
      allow read: if request.auth != null
                  && (resource == null
                      || request.auth.uid == resource.data.trainerId);
      allow create, update: if request.auth != null
                  && request.resource.data.trainerId == request.auth.uid
                  && request.resource.data.athleteId is string
                  && request.resource.data.athleteId.size() > 0;
      allow delete: if request.auth != null && resource.data.trainerId == request.auth.uid;
    }

    // Archivos privados que el PF sube sobre un alumno (PDFs, imágenes).
    // Mismo pattern que /athlete_notes: doc id es `{trainerId}_{athleteId}_{ts}`,
    // trainer-only R/W, alumno NUNCA los ve. Query paginable por
    // (trainerId, athleteId, uploadedAt desc). List gate garantiza que solo
    // el PF vinculado lista los archivos del alumno.
    match /athlete_files/{docId} {
      allow read, list: if request.auth != null
                  && request.auth.uid == resource.data.trainerId;
      allow create: if request.auth != null
                  && request.resource.data.trainerId == request.auth.uid
                  && request.resource.data.athleteId is string
                  && request.resource.data.athleteId.size() > 0
                  && request.resource.data.fileName is string
                  && request.resource.data.fileName.size() > 0
                  && request.resource.data.storagePath is string
                  && request.resource.data.downloadUrl is string
                  && request.resource.data.sizeBytes is int
                  && request.resource.data.sizeBytes > 0
                  && request.resource.data.sizeBytes <= 10 * 1024 * 1024;
      // Update no habilitado — para reemplazar contenido se borra y sube
      // de nuevo. Evita drift entre downloadUrl y storagePath.
      allow update: if false;
      allow delete: if request.auth != null
                  && request.auth.uid == resource.data.trainerId;
    }

    // Follow-up entries — log cronológico privado del PF sobre un alumno.
    // Mismo patrón que athlete_files: docId `{trainerId}_{athleteId}_{ts}`,
    // trainer-only R/W, alumno NUNCA lo ve. Update permite cambiar texto y
    // tag pero NO los identificadores (trainerId, athleteId, recordedAt).
    match /follow_up_entries/{docId} {
      allow read, list: if request.auth != null
                  && request.auth.uid == resource.data.trainerId;
      allow create: if request.auth != null
                  && request.resource.data.trainerId == request.auth.uid
                  && request.resource.data.athleteId is string
                  && request.resource.data.athleteId.size() > 0
                  && request.resource.data.text is string
                  && request.resource.data.text.size() > 0
                  && request.resource.data.text.size() < 5000
                  && request.resource.data.tag is string;
      allow update: if request.auth != null
                  && resource.data.trainerId == request.auth.uid
                  && request.resource.data.trainerId == resource.data.trainerId
                  && request.resource.data.athleteId == resource.data.athleteId
                  && request.resource.data.recordedAt == resource.data.recordedAt
                  && request.resource.data.text is string
                  && request.resource.data.text.size() > 0
                  && request.resource.data.text.size() < 5000
                  && request.resource.data.tag is string;
      allow delete: if request.auth != null
                  && request.auth.uid == resource.data.trainerId;
    }

    // Nutrition plan — un plan por par PF↔alumno, docId `{trainerId}_{athleteId}`.
    // Trainer-only R/W. El alumno NO lo ve en mobile todavía (feature scoped
    // aparte). Update preserva trainerId y athleteId. `meals` es un list —
    // no validamos la estructura en rules (validación se hace client-side).
    match /nutrition_plans/{docId} {
      allow read, list: if request.auth != null
                  && request.auth.uid == resource.data.trainerId;
      allow create: if request.auth != null
                  && request.resource.data.trainerId == request.auth.uid
                  && request.resource.data.athleteId is string
                  && request.resource.data.athleteId.size() > 0
                  && request.resource.data.title is string
                  && request.resource.data.title.size() < 200
                  && request.resource.data.meals is list;
      allow update: if request.auth != null
                  && resource.data.trainerId == request.auth.uid
                  && request.resource.data.trainerId == resource.data.trainerId
                  && request.resource.data.athleteId == resource.data.athleteId
                  && request.resource.data.title is string
                  && request.resource.data.title.size() < 200
                  && request.resource.data.meals is list;
      allow delete: if request.auth != null
                  && request.auth.uid == resource.data.trainerId;
    }

    // Payment records created by trainers against athletes (Pagos P1).
    match /payments/{paymentId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.trainerId
                      || request.auth.uid == resource.data.athleteId);
      // rules-hardening Slice C (AD-1 option b) — Coach-Collection Create
      // Requires Trainer Role: closes the "any athlete-role user forges a
      // payment debt naming themselves trainer" vector. Role-check only,
      // NOT a trainer_links relationship check — see design.md AD-1 /
      // engram obs #413.
      allow create: if request.auth != null
                  && request.resource.data.trainerId == request.auth.uid
                  && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'trainer'
                  && request.resource.data.athleteId is string
                  && request.resource.data.athleteId.size() > 0;
      // REQ-VENC-13: tightened update rule — field-level protection.
      // Follows the `reviews` rule pattern (keys().hasOnly + per-field equality).
      // Audited: markPaid/markManyPaid send only {status, paidAt} — still pass.
      // dueAt is pinned equal-to-existing so clients cannot set or alter it;
      // the CF bypasses rules via Admin SDK.
      // lastOverdueNotifiedAt is added to hasOnly (future-proof) and pinned so
      // clients cannot write it — the CF writes it via Admin SDK (bypasses rules).
      allow update: if request.auth != null
                  && resource.data.trainerId == request.auth.uid
                  && request.resource.data.keys().hasOnly([
                       'id', 'trainerId', 'athleteId', 'amountArs', 'concept',
                       'status', 'periodKey', 'createdAt', 'paidAt', 'dueAt',
                       'lastOverdueNotifiedAt'
                     ])
                  && request.resource.data.id == resource.data.id
                  && request.resource.data.trainerId == resource.data.trainerId
                  && request.resource.data.athleteId == resource.data.athleteId
                  && request.resource.data.amountArs == resource.data.amountArs
                  && request.resource.data.concept == resource.data.concept
                  && request.resource.data.createdAt == resource.data.createdAt
                  && request.resource.data.get('periodKey', null) == resource.data.get('periodKey', null)
                  && request.resource.data.get('dueAt', null) == resource.data.get('dueAt', null)
                  && request.resource.data.get('lastOverdueNotifiedAt', null) == resource.data.get('lastOverdueNotifiedAt', null);
      allow delete: if request.auth != null && resource.data.trainerId == request.auth.uid;
    }

    // Athlete → trainer reviews (Fase 6 Etapa 7).
    // Doc id is deterministic: `${linkId}_${athleteId}`.
    // REQ-RV-DATA-007. SCENARIO-580..585.
    //
    // rules-hardening Slice B (AD-1) — Review Create Requires Real Trainer
    // Link: `athleteId == auth.uid` + rating bounds alone are NOT sufficient
    // to prove a real coaching relationship — any athlete could otherwise
    // forge a 1-star (sabotage) or 5-star (self-boost-by-proxy) review for
    // ANY trainerId with no relationship at all. The doc-id is pinned to the
    // deterministic `${linkId}_${athleteId}` convention (mirrors
    // Review.idFor), and the named trainer_links/{linkId} document must be a
    // real, non-terminated relationship naming both parties. This is the
    // same cross-doc get()-gate idiom used for role checks elsewhere in this
    // file (e.g. the `gyms` create rule), applied here to a relationship
    // check instead of a role.
    //
    // Rules:
    //   read:   any authenticated user (needed for public profile display).
    //   create: athlete creates their own review (athleteId == auth.uid);
    //           doc-id must equal `${linkId}_${athleteId}`; the named
    //           trainer_links/{linkId} must exist with athleteId/trainerId
    //           matching the review payload and status in [active, paused]
    //           (a terminated link no longer proves a live relationship);
    //           rating must be 1..5; comment ≤500 chars.
    //   update: owner only; may change only rating, comment, updatedAt —
    //           preventing id/linkId/athleteId/trainerId/createdAt tampering.
    //   delete: always denied — only account-deletion CF may delete reviews.
    match /reviews/{reviewId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.athleteId
                    && reviewId == request.resource.data.linkId + '_' + request.resource.data.athleteId
                    && get(/databases/$(database)/documents/trainer_links/$(request.resource.data.linkId)).data.athleteId == request.auth.uid
                    && get(/databases/$(database)/documents/trainer_links/$(request.resource.data.linkId)).data.trainerId == request.resource.data.trainerId
                    && get(/databases/$(database)/documents/trainer_links/$(request.resource.data.linkId)).data.status in ['active', 'paused']
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && (!('comment' in request.resource.data)
                        || request.resource.data.comment == null
                        || request.resource.data.comment.size() <= 500);

      allow update: if request.auth != null
                    && request.auth.uid == resource.data.athleteId
                    && request.resource.data.keys().hasOnly(
                        ['id', 'linkId', 'athleteId', 'trainerId',
                         'rating', 'comment', 'createdAt', 'updatedAt'])
                    && request.resource.data.id == resource.data.id
                    && request.resource.data.linkId == resource.data.linkId
                    && request.resource.data.athleteId == resource.data.athleteId
                    && request.resource.data.trainerId == resource.data.trainerId
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && (!('comment' in request.resource.data)
                        || request.resource.data.comment == null
                        || request.resource.data.comment.size() <= 500);

      allow delete: if false;
    }
  }
}
